{
  "name": "opencode-recap",
  "version": "1.0.0",
  "description": "OpenCode TUI plugin — AI session recap in the sidebar",
  "type": "module",
  "exports": {
    "./tui": "./dist/tui.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild index.ts --bundle --format=esm --platform=node --packages=external --loader:.ts=tsx --jsx=automatic --jsx-import-source=@opentui/solid --outfile=dist/tui.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["opencode", "opencode-plugin"],
  "license": "MIT",
  "engines": {
    "opencode": ">=1.4.3"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.3",
    "@opentui/core": "^0.2.2",
    "@opentui/solid": "^0.2.2",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "esbuild": "^0.25.4"
  }
}
